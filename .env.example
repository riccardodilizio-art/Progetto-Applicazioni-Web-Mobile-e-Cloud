# ========================================
# Template variabili d'ambiente
# ========================================
# Copia questo file in .env nella root del progetto
# e compila i valori reali prima di avviare.

# Connessione al database PostgreSQL (Neon)
DB_CONNECTION=Host=<host>.neon.tech;Database=neondb;Username=<user>;Password=<password>;SSL Mode=Require;Trust Server Certificate=true;Timeout=60;Command Timeout=60;Channel Binding=Disable;

# Chiave di firma JWT (min 32 caratteri casuali)
Jwt__Key=<stringa-random-di-almeno-32-caratteri>

# URL pubblico del frontend (usato nelle email di reset password)
App__FrontendUrl=http://localhost:8080

# Configurazione SMTP (Gmail con App Password)
Smtp__Host=smtp.gmail.com
Smtp__Port=587
Smtp__Username=<tua-email>@gmail.com
Smtp__Password=<app-password-16-caratteri>
Smtp__FromEmail=<tua-email>@gmail.com
Smtp__FromName=Hotel Excelsior
Smtp__AdminEmail=<email-notifiche>
